# DeepSeek 文本模型：用于生成教案、作文评价、试卷讲评，以及基于奥威亚 OCR Markdown 生成教研诊断
DEEPSEEK_API_KEY=

# 百度 OCR：用于课文图片、作文图片、试卷图片，以及奥威亚 PDF/图表截图的第一遍文字提取保底
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 硅基流动视觉模型：用于读取 PyMuPDF 渲染出的奥威亚页面图片，做结构化 Markdown、表格还原和图表指标提取。
# 如果只有 1 个 key，填 SILICONFLOW_API_KEY 即可。
SILICONFLOW_API_KEY=

# 如果你申请了 5 个视觉识别 API Key，推荐按下面 5 行填写；系统会按页码轮换使用。
SILICONFLOW_API_KEY_1=
SILICONFLOW_API_KEY_2=
SILICONFLOW_API_KEY_3=
SILICONFLOW_API_KEY_4=
SILICONFLOW_API_KEY_5=

# 也可以不用上面的 5 行，改用一行逗号分隔：
# SILICONFLOW_API_KEYS=sk-key-1,sk-key-2,sk-key-3,sk-key-4,sk-key-5

SILICONFLOW_API_ENDPOINT=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct

# 单页视觉识别输出长度。默认 8192，避免表格/转写页被截断。
SILICONFLOW_VISION_MAX_TOKENS=8192
SILICONFLOW_VISION_TEMPERATURE=0.1
# 单页视觉识别超时，单位毫秒。全量 49 页时建议保留 120000 或更高。
SILICONFLOW_VISION_TIMEOUT_MS=120000

# 奥威亚 PDF 逐页识别并发数。默认 5；如果硅基流动限流或超时频繁，可改为 1-2。
AVIA_OCR_CONCURRENCY=5

# 奥威亚完整 OCR Markdown 进入最终诊断前的分块摘要配置，避免 DeepSeek 输入过长。
AVIA_EVIDENCE_CHUNK_CHARS=16000
AVIA_DIAGNOSIS_EVIDENCE_CHARS=28000

# 后台任务超过该时间没有更新时，刷新状态会尝试自动续跑。默认 10 分钟。
AVIA_JOB_STALE_MS=600000

# 百度 OCR 单次请求超时，单位毫秒。
BAIDU_OCR_TIMEOUT_MS=45000

# PyMuPDF 渲染配置。dpi=200 是清晰度和体积的平衡点。
AVIA_PDF_RENDER_DPI=200

# 0 表示全量读取所有 PDF 页面；调试时可改成 3、5、10。
AVIA_PDF_MAX_PAGES=0

# Python 命令。服务器若 python 指向不正确，可改成 python3 或具体路径。
PYTHON_BIN=python
