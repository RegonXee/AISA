# DeepSeek 文本模型：用于生成教案、作文评价、试卷讲评，以及基于结构化证据生成教师问题诊断
DEEPSEEK_API_KEY=

# 百度 OCR：用于课文图片、作文图片、试卷图片，以及千问未配置/失败时的图表截图 OCR 备用方案
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 千问/阿里云百炼多模态：用于读取奥威亚图片型 PDF、图表截图和页面截图
# QWEN_API_KEY 与 DASHSCOPE_API_KEY 二选一即可；推荐使用 QWEN_API_KEY。
QWEN_API_KEY=
DASHSCOPE_API_KEY=

# 百炼 OpenAI 兼容接口。通常不需要改。
QWEN_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 推荐 qwen-vl-max；也可按账号权限改为 qwen-vl-plus 等视觉模型。
QWEN_VISION_MODEL=qwen-vl-max

# 奥威亚 PDF 读取页数。0 表示全量读取 PDF 中所有可提取页面图片；正式分析建议全量。
# 如果演示时想降低成本/耗时，可以改成 8、12、16。
QWEN_VISION_MAX_PAGES=0

# 千问视觉分批读取页数。页数越大，单次请求越重；建议 3-5。
QWEN_VISION_BATCH_SIZE=4
